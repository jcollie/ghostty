[Unit]
Description=@NAME@
After=graphical-session.target
After=dbus.socket
Requires=dbus.socket

[Service]
Type=notify-reload
ReloadSignal=SIGUSR2
BusName=@APPID@
Environment=GHOSTTY_LOG=0
ExecStart=@GHOSTTY@ --gtk-single-instance=true --initial-window=false

[Install]
WantedBy=graphical-session.target
